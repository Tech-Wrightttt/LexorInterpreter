%% LEXOR STRESS TEST
SCRIPT AREA
START SCRIPT
DECLARE INT first=10, second
DECLARE BOOL status="FALSE"
DECLARE CHAR initial='J'
second = first
first = 20
status = "TRUE"
PRINT: "Values:" & first & "&" & second & $
PRINT: "Status is " & status & $
PRINT: "Character is: " & "[[]" & initial & "[]]"
END SCRIPT
%% Expected Output:
%% Values:20&10
%% Status is TRUE
%% Character is: [J]